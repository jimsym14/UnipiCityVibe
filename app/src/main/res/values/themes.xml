<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.UnipiCityVibe" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/unipi_red</item>
        <item name="colorOnPrimary">@color/text_inverted</item>
        <item name="colorSecondary">@color/unipi_blue</item>
        <item name="android:windowBackground">@color/system_background_primary</item>

        <item name="android:statusBarColor">@color/system_background_primary</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.UnipiCityVibe" parent="Base.Theme.UnipiCityVibe" />

    <style name="VibeText">
        <item name="android:textColor">@color/label_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="VibeText.LargeTitle">
        <item name="android:textSize">34sp</item>
        <item name="android:textColor">@color/unipi_blue</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="VibeText.Title1">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/label_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="VibeText.Headline">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/label_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="VibeText.Callout">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/unipi_red</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="VibeText.Caption">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/label_secondary</item>
    </style>

    <style name="VibeCard">
        <item name="cardBackgroundColor">@color/system_background_secondary</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="VibeInputContainer">
        <item name="cardBackgroundColor">@color/input_background</item>
        <item name="cardCornerRadius">10dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/separator</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="VibeButton">
        <item name="android:backgroundTint">@color/unipi_red</item>
        <item name="android:textColor">@color/text_inverted</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

</resources>